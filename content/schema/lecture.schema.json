{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://physics-codex.local/schemas/lecture.schema.json",
  "title": "Physics Codex Lecture",
  "type": "object",
  "required": [
    "volume",
    "chapter",
    "section",
    "title",
    "summary",
    "key_concepts",
    "examples",
    "source_reference",
    "source_file",
    "schema_version",
    "ingested_at"
  ],
  "properties": {
    "volume": { "type": "integer", "minimum": 1 },
    "chapter": { "type": "integer", "minimum": 1 },
    "section": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "key_concepts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_reference": { "type": "string", "minLength": 1 },
    "source_file": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "pattern": "^v[0-9]+$" },
    "ingested_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
