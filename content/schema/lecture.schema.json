{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://physics-codex.local/schemas/lecture.schema.json",
  "title": "Physics Codex Lecture",
  "type": "object",
  "required": [
    "volume",
    "chapter",
    "section",
    "unit_title",
    "unit_slug",
    "unit_summary",
    "title",
    "estimated_minutes",
    "summary",
    "learning_objectives",
    "key_concepts",
    "examples",
    "quick_recap",
    "equations",
    "worked_examples",
    "common_mistakes",
    "checkpoints",
    "interactive_lab",
    "challenge_sets",
    "source_reference",
    "source_file",
    "schema_version",
    "ingested_at"
  ],
  "properties": {
    "volume": { "type": "integer", "minimum": 1 },
    "chapter": { "type": "integer", "minimum": 1 },
    "section": { "type": "integer", "minimum": 1 },
    "unit_title": { "type": "string", "minLength": 1 },
    "unit_slug": { "type": "string", "minLength": 1 },
    "unit_summary": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "estimated_minutes": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "learning_objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "key_concepts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "quick_recap": { "type": "string", "minLength": 1 },
    "equations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "expression", "meaning", "variables"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "expression": { "type": "string", "minLength": 1 },
          "meaning": { "type": "string", "minLength": 1 },
          "variables": { "type": "string", "minLength": 1 }
        }
      }
    },
    "worked_examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "problem", "steps", "answer"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "problem": { "type": "string", "minLength": 1 },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "answer": { "type": "string", "minLength": 1 }
        }
      }
    },
    "common_mistakes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["mistake", "correction"],
        "properties": {
          "mistake": { "type": "string", "minLength": 1 },
          "correction": { "type": "string", "minLength": 1 }
        }
      }
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["prompt", "prediction", "reveal"],
        "properties": {
          "prompt": { "type": "string", "minLength": 1 },
          "prediction": { "type": "string", "minLength": 1 },
          "reveal": { "type": "string", "minLength": 1 }
        }
      }
    },
    "interactive_lab": {
      "type": "object",
      "required": [
        "title",
        "prompt",
        "x_key",
        "x_label",
        "x_min",
        "x_max",
        "x_step",
        "x_default",
        "x_unit",
        "y_key",
        "y_label",
        "y_min",
        "y_max",
        "y_step",
        "y_default",
        "y_unit",
        "formula",
        "output_label",
        "output_unit",
        "output_precision",
        "insight"
      ]
    },
    "challenge_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "prompt", "explanation"]
      }
    },
    "source_reference": { "type": "string", "minLength": 1 },
    "source_file": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "pattern": "^v[0-9]+$" },
    "ingested_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
